<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:models="using:ScreenBreak.Models"
             x:Class="ScreenBreak.Views.HistoryView">

    <Grid RowDefinitions="Auto,*" Margin="20">

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="History"
                   FontSize="28"
                   FontWeight="Bold"
                   FontFamily="Poppins"/>

        <!-- Card -->
        <Border Grid.Row="1"
                Margin="0,20,0,0"
                Background="White"
                CornerRadius="10"
                Padding="10">

            <Grid RowDefinitions="Auto,*">

                <!-- Header row -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="2*,*,*,*"
                      Margin="0,0,0,8">

                    <TextBlock Text="Date"       FontWeight="Bold"/>
                    <TextBlock Grid.Column="1"   Text="Type"      FontWeight="Bold"/>
                    <TextBlock Grid.Column="2"   Text="Duration"  FontWeight="Bold"/>
                    <TextBlock Grid.Column="3"   Text="Completed" FontWeight="Bold"/>

                </Grid>

                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">

                    <ItemsControl x:Name="HistoryItemsControl">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SessionRecord">

                                <Border Background="#F9F9F9"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,4">

                                    <Grid ColumnDefinitions="2*,*,*,*">
                                        <TextBlock Text="{Binding StartTime}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SessionType}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DurationSeconds}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Completed}"/>
                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>

            </Grid>

        </Border>

    </Grid>

</UserControl>